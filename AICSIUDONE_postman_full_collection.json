        { "name": "POST /api/expedientes/registrar", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Expediente de prueba\",\n  \"descripcion\": \"Descripción...\"\n}" }, "url": { "raw": "{{baseUrl}}/api/expedientes/registrar", "host": ["{{baseUrl}}"], "path": ["api","expedientes","registrar"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 201', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },

        { "name": "POST /api/v1/escenas", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"expedienteId\": 1,\n  \"descripcion\": \"Escena de prueba\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/escenas", "host": ["{{baseUrl}}"], "path": ["api","v1","escenas"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 201 or 200', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },

        { "name": "GET /api/v1/escenas/{id}", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/escenas/:id", "host": ["{{baseUrl}}"], "path": ["api","v1","escenas",":id"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 2xx', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },

        { "name": "PATCH /api/v1/escenas/{id}/iniciar-checklist", "request": { "method": "PATCH", "url": { "raw": "{{baseUrl}}/api/v1/escenas/:id/iniciar-checklist", "host": ["{{baseUrl}}"], "path": ["api","v1","escenas",":id","iniciar-checklist"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 2xx', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },

        { "name": "POST /api/v1/evidencias", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"escenaId\": 1,\n  \"descripcion\": \"Evidencia de prueba\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/evidencias", "host": ["{{baseUrl}}"], "path": ["api","v1","evidencias"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 201 or 200', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },

        { "name": "GET /api/v1/evidencias/{id}", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/evidencias/:id", "host": ["{{baseUrl}}"], "path": ["api","v1","evidencias",":id"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 2xx', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },

        { "name": "PATCH /api/v1/evidencias/{id}/numero", "request": { "method": "PATCH", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{ \"numero\": \"EV-001\" }" }, "url": { "raw": "{{baseUrl}}/api/v1/evidencias/:id/numero", "host": ["{{baseUrl}}"], "path": ["api","v1","evidencias",":id","numero"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 2xx', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },

        { "name": "PATCH /api/v1/evidencias/{id}/firmar/{investigadorId}", "request": { "method": "PATCH", "url": { "raw": "{{baseUrl}}/api/v1/evidencias/:id/firmar/:investigadorId", "host": ["{{baseUrl}}"], "path": ["api","v1","evidencias",":id","firmar",":investigadorId"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 2xx', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] }

      ]
    },
    {
      "name": "Guardia - Additional",
      "item": [
        { "name": "Localizaciones: POST /api/v1/localizaciones", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"municipio\": \"Ciudad\",\n  \"sector\": \"Centro\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/localizaciones", "host": ["{{baseUrl}}"], "path": ["api","v1","localizaciones"] } }, "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 201 or 200', function(){ pm.expect(pm.response.code).to.be.within(200,299); });" ] } } ] },
