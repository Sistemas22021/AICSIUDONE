# Variables de entorno para desarrollo local
# Copiar a .env y completar con tus valores
# NUNCA commitear el archivo .env al repositorio

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Opciones gratuitas para Fase 1:
#
# Neon (recomendado):
#   URL: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/sso_db?sslmode=require
#   Obtener en: https://neon.tech → New Project → Connection Details → JDBC
#
# Supabase:
#   URL: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Obtener en: https://supabase.com → Settings → Database → Connection string (JDBC)

DATASOURCE_URL=jdbc:postgresql://REEMPLAZAR_CON_TU_URL
DATASOURCE_USERNAME=REEMPLAZAR
DATASOURCE_PASSWORD=REEMPLAZAR

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT.
# DEBE ser al menos 32 caracteres. Generar con:
#   openssl rand -base64 32
# ESTE VALOR DEBE SER IDENTICO en auth-service y api-gateway

JWT_SECRET=REEMPLAZAR_CON_STRING_ALEATORIO_DE_32_CHARS_MINIMO

# ─── URLs de los servicios (para desarrollo local con Docker) ─────────────────
CONFIG_SERVER_URL=http://localhost:8888
EUREKA_HOST=localhost

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Estas variables se inyectan en el build de Vite (prefijo VITE_)
VITE_API_GATEWAY_URL=http://localhost:8090
VITE_LOGIN_MFE_URL=http://localhost:3000
VITE_CONSUMER_APP_URL=http://localhost:3001

# ─── AWS (solo para deploy en AWS) ───────────────────────────────────────────
# NO completar en desarrollo local; usar IAM roles en CI/CD
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Target de deploy del frontend: 's3' o 'vercel'
DEPLOY_TARGET=s3
