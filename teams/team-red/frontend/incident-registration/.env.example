# URL del backend propio (guardia-core, Spring Boot)
# Cambiar por la URL real cuando el backend esté disponible
VITE_API_URL=http://localhost:8080

# URL del API Gateway del sistema de login
# (main/backend/api-gateway). Se usa para refrescar la sesión SSO
# (POST /api/v1/auth/refresh) al recargar la página.
VITE_API_GATEWAY_URL=http://localhost:8090

# URL del Login MFE del sistema de login centralizado del profesor
# (main/frontend/login-mfe). Aquí se redirige cuando no hay una sesión
# SSO válida.
VITE_LOGIN_MFE_URL=http://localhost:3000