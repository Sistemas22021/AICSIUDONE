# Variables de entorno para Prison Service (Backend)
# Copiar este archivo como .env y completar con tus valores
# NUNCA commitear el archivo .env al repositorio

# ─── Base de Datos PostgreSQL (Supabase) ──────────────────────────────────
# Obtener estos datos desde: https://supabase.com → Project Settings → Database
# Usar el connection string de tipo JDBC
DATASOURCE_URL=jdbc:postgresql://aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require
DATASOURCE_USERNAME=postgres.tu_usuario
DATASOURCE_PASSWORD=tu_contraseña
