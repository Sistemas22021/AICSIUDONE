# ─── Variables de Entorno para Equipo Verde Web (Módulo de Balística) ─────────
# Copiar este archivo como `.env` para desarrollo local.
# Para producción en Vercel, estas variables se configuran en GitHub Secrets o en Vercel.

# URL del API Gateway principal (Spring Cloud Gateway)
VITE_API_GATEWAY_URL=http://localhost:8090

# URL del Microfrontend de Autenticación / Login (MFE Login)
VITE_LOGIN_MFE_URL=http://localhost:3000
