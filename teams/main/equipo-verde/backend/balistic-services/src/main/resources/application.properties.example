# ============================================================
# EJEMPLO DE CONFIGURACIĂ“N - Copia este archivo como:
#   application.properties
# y reemplaza los valores con tus credenciales locales.
# ============================================================

# --- Almacenamiento ---
storage.location=${STORAGE_LOCATION:uploads}
storage.type=${STORAGE_TYPE:s3}

# --- Base de Datos PostgreSQL ---
spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USER}
spring.datasource.password=${DB_PASSWORD}
spring.jpa.hibernate.ddl-auto=${JPA_DDL_AUTO:update}
spring.sql.init.mode=${SQL_INIT_MODE:never}
spring.jpa.defer-datasource-initialization=true
spring.jpa.show-sql=${JPA_SHOW_SQL:false}
spring.jpa.properties.hibernate.format_sql=true

# AWS S3 / LocalStack Configuration
aws.s3.endpoint=${AWS_S3_ENDPOINT:http://127.0.0.1:4566}
aws.s3.region=${AWS_S3_REGION:us-east-1}
aws.s3.access-key=${S3_ACCESS_KEY:test}
aws.s3.secret-key=${S3_SECRET_KEY:test}
aws.s3.bucket-name=${AWS_S3_BUCKET:sistema-balistico-images}