# Supabase PostgreSQL (Dashboard → Project Settings → Database → Connection string URI)
# Convert to JDBC and keep sslmode=require:
#   jdbc:postgresql://db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password

# JPA / SQL init (safe defaults for cloud; use create+always only for empty throwaway DBs)
JPA_DDL_AUTO=validate
SQL_INIT_MODE=never
JPA_SHOW_SQL=false

# LocalStack S3 (credentials are dummy for local)
STORAGE_TYPE=s3
AWS_S3_ENDPOINT=http://localstack:4566
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=sistema-balistico-images
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
STORAGE_LOCATION=uploads
